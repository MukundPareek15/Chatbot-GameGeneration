; ============================================================
; Minesweeper AI Chatbot — API Configuration
; ============================================================
; 1. Copy this file to Config/Secrets.ini
; 2. Fill in your Provider and APIKey
; 3. Secrets.ini is gitignored and will never be committed
; ============================================================

[AI]
; Provider: gemini | openai | claude
Provider=gemini

; Your API key for the chosen provider.
; Get one from:
;   Gemini -> https://aistudio.google.com/app/apikey
;   OpenAI -> https://platform.openai.com/api-keys
;   Claude -> https://console.anthropic.com/settings/keys
APIKey=YOUR_API_KEY_HERE

; Model is optional — sensible defaults are used if left blank.
;
; Gemini options (free tier available):
;   gemini-2.0-flash          <- default
;   gemini-1.5-flash
;   gemini-1.5-flash-8b       <- lightest, separate free quota
;
; OpenAI options (paid):
;   gpt-4o-mini               <- default, cheapest
;   gpt-4o
;
; Claude options (paid, free tier via Console):
;   claude-haiku-4-5-20251001 <- default, fastest/cheapest
;   claude-sonnet-4-6
Model=
